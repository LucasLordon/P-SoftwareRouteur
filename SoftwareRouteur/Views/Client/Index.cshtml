@model ClientIndexViewModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Page_Title"].Value;
}

<!-- Page header -->
<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">@Localizer["Page_Title"]</h1>
        <p class="sh-page-subtitle">@Localizer["Page_Subtitle"]</p>
    </div>
    <button class="sh-btn-primary" onclick="document.getElementById('addClientModal').classList.add('show')">
        <i class="bi bi-plus-lg"></i> @Localizer["Btn_Add"]
    </button>
</div>

<!-- Clients card -->
<div class="sh-card">
    <div class="sh-card-header">
        <h2 class="sh-card-title">@Localizer["Table_Title", Model.TotalClients]</h2>
    </div>

    @if (Model.Clients.Any())
    {
        <table class="sh-table">
            <thead>
            <tr>
                <th>Hostname</th>
                <th>IP</th>
                <th class="sh-col-actions">@Localizer["Col_Actions"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var client in Model.Clients)
            {
                <tr>
                    <td class="sh-col-client">@client.Hostname</td>
                    <td class="sh-col-dest">@client.IpAddress</td>
                    <td class="sh-col-actions">
                        <form method="post" asp-controller="Firewall" asp-action="Index" asp-route-search="@client.Hostname" class="sh-form-inline">
                            <input type="hidden" name="id" value="@client.Id"/>
                            <button type="submit" class="sh-action-btn sh-eye" title="@Localizer["Tooltip_ViewRules"]">
                                <i class="bi bi-eye"></i>
                            </button>
                        </form>
                        <button class="sh-action-btn" title="@Localizer["Tooltip_Edit"]"
                                onclick="openEditClientModal(@client.Id, '@client.Hostname', '@client.IpAddress')">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <form method="post" asp-action="Delete" class="sh-form-inline"
                              onsubmit="return confirm('@Localizer["Confirm_Delete"]')">
                            <input type="hidden" name="id" value="@client.Id"/>
                            <button type="submit" class="sh-action-btn sh-delete" title="@Localizer["Tooltip_Delete"]">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
    else
    {
        <div class="sh-empty">
            <i class="bi bi-people"></i>
            <p>@Localizer["Empty"]</p>
        </div>
    }

    @if (Model.TotalPages > 1)
    {
        <div class="sh-pagination">
            <a class="sh-page-btn @(!Model.HasPrevious ? "disabled" : "")"
               asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">
                <i class="bi bi-chevron-left"></i>
            </a>
            <span class="sh-page-info">@Model.Page / @Model.TotalPages</span>
            <a class="sh-page-btn @(!Model.HasNext ? "disabled" : "")"
               asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">
                <i class="bi bi-chevron-right"></i>
            </a>
        </div>
    }
</div>

<!-- Add Client Modal -->
<div class="sh-modal-backdrop" id="addClientModal" onclick="if(event.target===this) this.classList.remove('show')">
    <div class="sh-modal">
        <div class="sh-modal-header">
            <h3 class="sh-modal-title">@Localizer["Modal_Add_Title"]</h3>
            <button class="sh-modal-close" onclick="document.getElementById('addClientModal').classList.remove('show')">&times;</button>
        </div>
        <form method="post" asp-action="Create">
            <div class="sh-modal-body">
                <div class="sh-form-group">
                    <label class="sh-form-label">@Localizer["Field_Hostname"]</label>
                    <input type="text" name="hostname" class="sh-input"
                           placeholder="@Localizer["Placeholder_Hostname"]" required/>
                </div>
                <div class="sh-form-group">
                    <label class="sh-form-label">@Localizer["Field_IP"]</label>
                    <input type="text" name="ipAddress" class="sh-input"
                           placeholder="@Localizer["Placeholder_IP"]" required
                           pattern="^(\d{1,3}\.){3}\d{1,3}$"
                           title="Format: xxx.xxx.xxx.xxx"/>
                </div>
            </div>
            <div class="sh-modal-footer">
                <button type="button" class="sh-btn-cancel"
                        onclick="document.getElementById('addClientModal').classList.remove('show')">@Localizer["Btn_Cancel"]</button>
                <button type="submit" class="sh-btn-submit">
                    <i class="bi bi-plus-lg"></i> @Localizer["Btn_Submit_Add"]
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Client Modal -->
<div class="sh-modal-backdrop" id="editClientModal" onclick="if(event.target===this) this.classList.remove('show')">
    <div class="sh-modal">
        <div class="sh-modal-header">
            <h3 class="sh-modal-title">@Localizer["Modal_Edit_Title"]</h3>
            <button class="sh-modal-close" onclick="document.getElementById('editClientModal').classList.remove('show')">&times;</button>
        </div>
        <form method="post" asp-action="Edit">
            <input type="hidden" name="id" id="editClientId"/>
            <div class="sh-modal-body">
                <div class="sh-form-group">
                    <label class="sh-form-label">@Localizer["Field_Hostname"]</label>
                    <input type="text" name="hostname" id="editClientHostname" class="sh-input" required/>
                </div>
                <div class="sh-form-group">
                    <label class="sh-form-label">@Localizer["Field_IP"]</label>
                    <input type="text" name="ipAddress" id="editClientIp" class="sh-input" required
                           pattern="^(\d{1,3}\.){3}\d{1,3}$"
                           title="Format: xxx.xxx.xxx.xxx"/>
                </div>
            </div>
            <div class="sh-modal-footer">
                <button type="button" class="sh-btn-cancel"
                        onclick="document.getElementById('editClientModal').classList.remove('show')">@Localizer["Btn_Cancel"]</button>
                <button type="submit" class="sh-btn-submit">@Localizer["Btn_Save"]</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openEditClientModal(id, hostname, ipAddress) {
            document.getElementById('editClientId').value = id;
            document.getElementById('editClientHostname').value = hostname;
            document.getElementById('editClientIp').value = ipAddress;
            document.getElementById('editClientModal').classList.add('show');
        }
    </script>
}
