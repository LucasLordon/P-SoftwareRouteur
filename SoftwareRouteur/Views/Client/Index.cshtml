@model List<Client>
@{
    ViewData["Title"] = "Gestion des clients";
    var clientCount = Model.Count;
}

<!-- Page header -->
<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">Gestion des clients</h1>
        <p class="sh-page-subtitle">Ajouter, modifier ou supprimer des clients du réseau</p>
    </div>
    <button class="sh-btn-primary" onclick="document.getElementById('addClientModal').classList.add('show')">
        <i class="bi bi-plus-lg"></i> Ajouter un client
    </button>
</div>

<!-- Clients card -->
<div class="sh-card">
    <div class="sh-card-header">
        <h2 class="sh-card-title">Clients existants (@clientCount)</h2>
    </div>

    @if (Model.Any())
    {
        <table class="sh-table">
            <thead>
            <tr>
                <th>Hostname</th>
                <th>Adresse IP</th>
                <th style="text-align: right;">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var client in Model)
            {
                <tr>
                    <td class="sh-col-client">@client.Hostname</td>
                    <td class="sh-col-dest">@client.IpAddress</td>
                    <td class="sh-col-actions">
                        <form method="post" asp-controller="Firewall" asp-action="Index" asp-route-search="@client.Hostname" style="display:inline">
                            <input type="hidden" name="id" value="@client.Id"/>
                            <button type="submit" class="sh-action-btn sh-eye" title="Voir les règles du client">
                                <i class="bi bi-eye"></i>
                            </button>
                        </form>
                        <button class="sh-action-btn" title="Modifier"
                                onclick="openEditClientModal(@client.Id, '@client.Hostname', '@client.IpAddress')">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <form method="post" asp-action="Delete" style="display:inline"
                              onsubmit="return confirm('Supprimer ce client ? Les règles associées seront également supprimées.')">
                            <input type="hidden" name="id" value="@client.Id"/>
                            <button type="submit" class="sh-action-btn sh-delete" title="Supprimer">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
    else
    {
        <div class="sh-empty">
            <i class="bi bi-people"></i>
            <p>Aucun client enregistré. Cliquez sur « Ajouter un client » pour commencer.</p>
        </div>
    }
</div>

<!-- Add Client Modal -->
<div class="sh-modal-backdrop" id="addClientModal" onclick="if(event.target===this) this.classList.remove('show')">
    <div class="sh-modal">
        <div class="sh-modal-header">
            <h3 class="sh-modal-title">Ajouter un client</h3>
            <button class="sh-modal-close" onclick="document.getElementById('addClientModal').classList.remove('show')">&times;</button>
        </div>
        <form method="post" asp-action="Create">
            <div class="sh-modal-body">
                <div class="sh-form-group">
                    <label class="sh-form-label">Hostname</label>
                    <input type="text" name="hostname" class="sh-input"
                           placeholder="ex: laptop-alice" required/>
                </div>
                <div class="sh-form-group">
                    <label class="sh-form-label">Adresse IP</label>
                    <input type="text" name="ipAddress" class="sh-input"
                           placeholder="ex: 192.168.15.101" required
                           pattern="^(\d{1,3}\.){3}\d{1,3}$"
                           title="Format: xxx.xxx.xxx.xxx"/>
                </div>
            </div>
            <div class="sh-modal-footer">
                <button type="button" class="sh-btn-cancel"
                        onclick="document.getElementById('addClientModal').classList.remove('show')">Annuler</button>
                <button type="submit" class="sh-btn-submit">
                    <i class="bi bi-plus-lg"></i> Ajouter
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Client Modal -->
<div class="sh-modal-backdrop" id="editClientModal" onclick="if(event.target===this) this.classList.remove('show')">
    <div class="sh-modal">
        <div class="sh-modal-header">
            <h3 class="sh-modal-title">Modifier le client</h3>
            <button class="sh-modal-close" onclick="document.getElementById('editClientModal').classList.remove('show')">&times;</button>
        </div>
        <form method="post" asp-action="Edit">
            <input type="hidden" name="id" id="editClientId"/>
            <div class="sh-modal-body">
                <div class="sh-form-group">
                    <label class="sh-form-label">Hostname</label>
                    <input type="text" name="hostname" id="editClientHostname" class="sh-input" required/>
                </div>
                <div class="sh-form-group">
                    <label class="sh-form-label">Adresse IP</label>
                    <input type="text" name="ipAddress" id="editClientIp" class="sh-input" required
                           pattern="^(\d{1,3}\.){3}\d{1,3}$"
                           title="Format: xxx.xxx.xxx.xxx"/>
                </div>
            </div>
            <div class="sh-modal-footer">
                <button type="button" class="sh-btn-cancel"
                        onclick="document.getElementById('editClientModal').classList.remove('show')">Annuler</button>
                <button type="submit" class="sh-btn-submit">Enregistrer</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openEditClientModal(id, hostname, ipAddress) {
            document.getElementById('editClientId').value = id;
            document.getElementById('editClientHostname').value = hostname;
            document.getElementById('editClientIp').value = ipAddress;
            document.getElementById('editClientModal').classList.add('show');
        }
    </script>
}