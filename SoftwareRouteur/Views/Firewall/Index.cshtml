@model FirewallIndexViewModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Page_Title"].Value;
    var ruleCount = Model.Rules.Count;
}

<!-- Page header -->
<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">@Localizer["Page_Title"]</h1>
        <p class="sh-page-subtitle">@Localizer["Page_Subtitle"]</p>
    </div>
    <button class="sh-btn-primary" onclick="document.getElementById('addModal').classList.add('show')">
        <i class="bi bi-plus-lg"></i> @Localizer["Btn_Add"]
    </button>
</div>

<!-- Rules card -->
<div class="sh-card">
    <div class="sh-card-header">
        <h2 class="sh-card-title">@Localizer["Table_Label"] (<span id="visibleCount">@ruleCount</span> / @ruleCount)</h2>
    </div>

    <!-- Filters -->
    <div class="sh-filters">
        <div>
            <label class="sh-filter-label">@Localizer["Filter_Search"]</label>
            <div class="sh-search-wrapper">
                <i class="bi bi-search"></i>
                <input type="text" class="sh-input sh-input-search" id="searchInput"
                       placeholder="@Localizer["Filter_Search_Placeholder"]" oninput="filterTable(); showAutocomplete()"
                       onfocus="showAutocomplete()" autocomplete="off"/>
                <div class="sh-autocomplete" id="autocompleteList"></div>
            </div>
        </div>
        <div>
            <label class="sh-filter-label">@Localizer["Filter_Type"]</label>
            <select class="sh-input" id="filterType" onchange="filterTable()">
                <option value="">@Localizer["Filter_Type_All"]</option>
                <option value="domain">domain</option>
                <option value="ip">ip</option>
                <option value="cidr">cidr</option>
            </select>
        </div>
        <div>
            <label class="sh-filter-label">@Localizer["Filter_Action_Label"]</label>
            <select class="sh-input" id="filterAction" onchange="filterTable()">
                <option value="">@Localizer["Filter_Action_All"]</option>
                <option value="deny">deny</option>
                <option value="allow">allow</option>
            </select>
        </div>
    </div>

    <!-- Table -->
    @if (Model.Rules.Any())
    {
        <table class="sh-table sh-table-rules" id="rulesTable">
            <thead>
            <tr>
                <th class="sh-sortable" data-col="0" onclick="sortTable(0)">
                    @Localizer["Col_Client"] <span class="sh-sort-icon">⇅</span>
                </th>
                <th class="sh-sortable" data-col="1" onclick="sortTable(1)">
                    @Localizer["Col_Type"] <span class="sh-sort-icon">⇅</span>
                </th>
                <th class="sh-sortable" data-col="2" onclick="sortTable(2)">
                    @Localizer["Col_Dest"] <span class="sh-sort-icon">⇅</span>
                </th>
                <th class="sh-sortable" data-col="3" onclick="sortTable(3)">
                    @Localizer["Col_Action"] <span class="sh-sort-icon">⇅</span>
                </th>
                <th class="sh-col-actions">@Localizer["Col_Actions"]</th>
            </tr>
            </thead>
            <tbody id="rulesTableBody">
            @foreach (var rule in Model.Rules)
            {
                <tr data-client="@rule.Client?.Hostname?.ToLower()"
                    data-dest="@rule.Destination.ToLower()"
                    data-type="@rule.RuleType"
                    data-action="@rule.Action">
                    <td class="sh-col-client">@rule.Client?.Hostname</td>
                    <td><span class="sh-badge sh-badge-type">@rule.RuleType</span></td>
                    <td class="sh-col-dest">@rule.Destination</td>
                    <td data-badge-type="@rule.RuleType">
                        <span class="sh-badge @(rule.Action == "deny" ? "sh-badge-deny" : "sh-badge-allow")">
                            @rule.Action
                        </span>
                    </td>
                    <td class="sh-col-actions">
                        <button class="sh-action-btn" title="@Localizer["Tooltip_Edit"]"
                                onclick="openEditModal(@rule.Id, @rule.ClientId, '@rule.RuleType', '@rule.Destination', '@rule.Action')">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <form method="post" asp-action="Delete" class="sh-form-inline"
                              onsubmit="return confirm('@Localizer["Confirm_Delete"]')">
                            <input type="hidden" name="id" value="@rule.Id"/>
                            <button type="submit" class="sh-action-btn sh-delete" title="@Localizer["Tooltip_Delete"]">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
    else
    {
        <div class="sh-empty">
            <i class="bi bi-shield-slash"></i>
            <p>@Localizer["Empty"]</p>
        </div>
    }

    <div class="sh-pagination" id="paginationControls">
        <button class="sh-page-btn" id="btnPrev" onclick="changePage(-1)">
            <i class="bi bi-chevron-left"></i>
        </button>
        <span class="sh-page-info" id="pageInfo"></span>
        <button class="sh-page-btn" id="btnNext" onclick="changePage(1)">
            <i class="bi bi-chevron-right"></i>
        </button>
        <select class="sh-page-size-select" id="pageSizeSelect" onchange="changePageSize(this.value)">
            <option value="5">5 / page</option>
            <option value="10" selected>10 / page</option>
            <option value="25">25 / page</option>
            <option value="50">50 / page</option>
        </select>
    </div>
</div>

<!-- Add Modal -->
<div class="sh-modal-backdrop" id="addModal" onclick="if(event.target===this) this.classList.remove('show')">
    <div class="sh-modal">
        <div class="sh-modal-header">
            <h3 class="sh-modal-title">@Localizer["Modal_Add_Title"]</h3>
            <button class="sh-modal-close" onclick="document.getElementById('addModal').classList.remove('show')">&times;</button>
        </div>
        <form method="post" asp-action="Create">
            <div class="sh-modal-body">
                <div class="sh-form-group">
                    <label class="sh-form-label">@Localizer["Field_Client"]</label>
                    <select name="clientId" class="sh-input" required>
                        <option value="" disabled selected>@Localizer["Select_Client"]</option>
                        @foreach (var client in Model.Clients)
                        {
                            <option value="@client.Id">@client.Hostname (@client.IpAddress)</option>
                        }
                    </select>
                </div>
                <div class="sh-form-group">
                    <label class="sh-form-label">@Localizer["Field_Type"]</label>
                    <select name="ruleType" class="sh-input" required>
                        <option value="domain">@Localizer["Type_Domain"]</option>
                        <option value="ip">@Localizer["Type_IP"]</option>
                        <option value="cidr">@Localizer["Type_CIDR"]</option>
                    </select>
                </div>
                <div class="sh-form-group">
                    <label class="sh-form-label">@Localizer["Field_Dest"]</label>
                    <input type="text" name="destination" class="sh-input"
                           placeholder="ex: www.youtube.com ou 172.217.0.0/16" required/>
                </div>
                <div class="sh-form-group">
                    <label class="sh-form-label">@Localizer["Field_Action"]</label>
                    <select name="action" class="sh-input" required>
                        <option value="deny">@Localizer["Action_Deny"]</option>
                        <option value="allow">@Localizer["Action_Allow"]</option>
                    </select>
                </div>
            </div>
            <div class="sh-modal-footer">
                <button type="button" class="sh-btn-cancel"
                        onclick="document.getElementById('addModal').classList.remove('show')">@Localizer["Btn_Cancel"]</button>
                <button type="submit" class="sh-btn-submit">
                    <i class="bi bi-plus-lg"></i> @Localizer["Btn_Submit_Add"]
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div class="sh-modal-backdrop" id="editModal" onclick="if(event.target===this) this.classList.remove('show')">
    <div class="sh-modal">
        <div class="sh-modal-header">
            <h3 class="sh-modal-title">@Localizer["Modal_Edit_Title"]</h3>
            <button class="sh-modal-close" onclick="document.getElementById('editModal').classList.remove('show')">&times;</button>
        </div>
        <form method="post" asp-action="Edit">
            <input type="hidden" name="id" id="editId"/>
            <div class="sh-modal-body">
                <div class="sh-form-group">
                    <label class="sh-form-label">@Localizer["Field_Client"]</label>
                    <select name="clientId" id="editClientId" class="sh-input" required>
                        @foreach (var client in Model.Clients)
                        {
                            <option value="@client.Id">@client.Hostname (@client.IpAddress)</option>
                        }
                    </select>
                </div>
                <div class="sh-form-group">
                    <label class="sh-form-label">@Localizer["Field_Type"]</label>
                    <select name="ruleType" id="editRuleType" class="sh-input" required>
                        <option value="domain">@Localizer["Type_Domain"]</option>
                        <option value="ip">@Localizer["Type_IP"]</option>
                        <option value="cidr">@Localizer["Type_CIDR"]</option>
                    </select>
                </div>
                <div class="sh-form-group">
                    <label class="sh-form-label">@Localizer["Field_Dest"]</label>
                    <input type="text" name="destination" id="editDestination" class="sh-input" required/>
                </div>
                <div class="sh-form-group">
                    <label class="sh-form-label">@Localizer["Field_Action"]</label>
                    <select name="action" id="editAction" class="sh-input" required>
                        <option value="deny">@Localizer["Action_Deny"]</option>
                        <option value="allow">@Localizer["Action_Allow"]</option>
                    </select>
                </div>
            </div>
            <div class="sh-modal-footer">
                <button type="button" class="sh-btn-cancel"
                        onclick="document.getElementById('editModal').classList.remove('show')">@Localizer["Btn_Cancel"]</button>
                <button type="submit" class="sh-btn-submit">@Localizer["Btn_Save"]</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>

        // Auto-fill search from URL parameter
        const urlParams = new URLSearchParams(window.location.search);
        const searchParam = urlParams.get('search');
        if (searchParam) {
            document.getElementById('searchInput').value = searchParam;
            filterTable();
        }

        // ── Autocomplete data from server ──
        const autocompleteData = [
            @foreach (var rule in Model.Rules)
            {
            @: { label: "client", value: "@rule.Client?.Hostname" },
            @: { label: "destination", value: "@rule.Destination" },
            }
            @foreach (var client in Model.Clients)
            {
            @: { label: "client", value: "@client.Hostname" },
            }
        ];

        // Deduplicate
        const uniqueSuggestions = [];
        const seen = new Set();
        autocompleteData.forEach(item => {
            const key = item.label + ':' + item.value;
            if (!seen.has(key) && item.value) {
                seen.add(key);
                uniqueSuggestions.push(item);
            }
        });

        function showAutocomplete() {
            const input = document.getElementById('searchInput');
            const list = document.getElementById('autocompleteList');
            const val = input.value.toLowerCase();

            if (!val) {
                list.classList.remove('show');
                return;
            }

            const matches = uniqueSuggestions
                .filter(s => s.value.toLowerCase().includes(val))
                .slice(0, 5);

            if (matches.length === 0) {
                list.classList.remove('show');
                return;
            }

            list.innerHTML = matches.map(m =>
                `<div class="sh-autocomplete-item" onclick="selectSuggestion('${m.value}')">
                    <span class="sh-ac-label">${m.label}</span>
                    <span>${m.value}</span>
                </div>`
            ).join('');
            list.classList.add('show');
        }

        function selectSuggestion(value) {
            document.getElementById('searchInput').value = value;
            document.getElementById('autocompleteList').classList.remove('show');
            filterTable();
        }

        // Close autocomplete on click outside
        document.addEventListener('click', function (e) {
            if (!e.target.closest('.sh-search-wrapper')) {
                document.getElementById('autocompleteList').classList.remove('show');
            }
        });

        // ── Pagination ──
        let PAGE_SIZE = 10;
        let currentPage = 1;

        function renderPage() {
            const rows = Array.from(document.querySelectorAll('#rulesTableBody tr'));
            const matched = rows.filter(r => r.dataset.match !== 'false');
            const totalPages = Math.max(1, Math.ceil(matched.length / PAGE_SIZE));
            currentPage = Math.min(currentPage, totalPages);
            const start = (currentPage - 1) * PAGE_SIZE;

            rows.forEach(row => { row.style.display = 'none'; });
            matched.slice(start, start + PAGE_SIZE).forEach(row => { row.style.display = ''; });

            document.getElementById('visibleCount').textContent = matched.length;
            document.getElementById('pageInfo').textContent = totalPages > 1 ? `${currentPage} / ${totalPages}` : '';
            document.getElementById('btnPrev').disabled = currentPage <= 1;
            document.getElementById('btnNext').disabled = currentPage >= totalPages;
            document.getElementById('btnPrev').style.display = totalPages > 1 ? '' : 'none';
            document.getElementById('btnNext').style.display = totalPages > 1 ? '' : 'none';
        }

        function changePage(delta) {
            currentPage += delta;
            renderPage();
        }

        function changePageSize(val) {
            PAGE_SIZE = parseInt(val);
            currentPage = 1;
            renderPage();
        }

        // ── Filter table ──
        function filterTable() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const typeFilter = document.getElementById('filterType').value;
            const actionFilter = document.getElementById('filterAction').value;
            const rows = document.querySelectorAll('#rulesTableBody tr');

            rows.forEach(row => {
                const client = row.dataset.client || '';
                const dest = row.dataset.dest || '';
                const type = row.dataset.type || '';
                const action = row.dataset.action || '';

                const matchSearch = !search || client.includes(search) || dest.includes(search);
                const matchType = !typeFilter || type === typeFilter;
                const matchAction = !actionFilter || action === actionFilter;

                row.dataset.match = (matchSearch && matchType && matchAction) ? 'true' : 'false';
            });

            currentPage = 1;
            renderPage();
        }

        // Init
        document.querySelectorAll('#rulesTableBody tr').forEach(r => r.dataset.match = 'true');
        renderPage();

        // ── Sort table ──
        let sortCol = -1;
        let sortAsc = true;

        function sortTable(colIndex) {
            const tbody = document.getElementById('rulesTableBody');
            const rows = Array.from(tbody.querySelectorAll('tr'));
            const headers = document.querySelectorAll('#rulesTable thead th.sh-sortable');

            if (sortCol === colIndex) {
                sortAsc = !sortAsc;
            } else {
                sortCol = colIndex;
                sortAsc = true;
            }

            headers.forEach(th => th.classList.remove('sh-sort-active'));
            headers[colIndex].classList.add('sh-sort-active');

            const keys = ['client', 'type', 'dest', 'action'];
            const key = keys[colIndex];

            rows.sort((a, b) => {
                const valA = a.dataset[key] || '';
                const valB = b.dataset[key] || '';
                const cmp = valA.localeCompare(valB);
                return sortAsc ? cmp : -cmp;
            });

            rows.forEach(row => tbody.appendChild(row));

            const icon = headers[colIndex].querySelector('.sh-sort-icon');
            icon.textContent = sortAsc ? '↑' : '↓';
            headers.forEach((th, i) => {
                if (i !== colIndex) {
                    th.querySelector('.sh-sort-icon').textContent = '⇅';
                }
            });
        }

        // ── Edit modal ──
        function openEditModal(id, clientId, ruleType, destination, action) {
            document.getElementById('editId').value = id;
            document.getElementById('editClientId').value = clientId;
            document.getElementById('editRuleType').value = ruleType;
            document.getElementById('editDestination').value = destination;
            document.getElementById('editAction').value = action;
            document.getElementById('editModal').classList.add('show');
        }
    </script>
}
