@model LoginViewModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Card_Title"].Value;
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@Localizer["Page_Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body class="login-body">
<div class="login-wrapper">
    <!-- Branding -->
    <div class="login-brand">
        <div class="login-brand-icon">
            <i class="bi bi-shield-check"></i>
        </div>
        <h1 class="login-brand-title">SafeHome</h1>
        <p class="login-brand-subtitle">@Localizer["Brand_Subtitle"]</p>
    </div>

    <!-- Login card -->
    <div class="login-card">
        <h2 class="login-card-title">@Localizer["Card_Title"]</h2>

        @if (Model.Error != null)
        {
            <div class="login-error">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @Model.Error
            </div>
        }

        <form method="post" asp-action="Login">
            <div class="login-form-group">
                <label class="login-label">@Localizer["Field_Username"]</label>
                <input type="text" name="username" class="login-input"
                       placeholder="@Localizer["Placeholder_Username"]" required autofocus/>
            </div>
            <div class="login-form-group">
                <label class="login-label">@Localizer["Field_Password"]</label>
                <input type="password" name="password" class="login-input"
                       placeholder="••••••" required/>
            </div>
            <button type="submit" class="login-btn">@Localizer["Btn_Submit"]</button>
        </form>
    </div>

    <!-- Sélecteur de langue -->
    <div style="text-align:center; margin-top: 1.5rem;">
        <form asp-controller="Culture" asp-action="Set" method="post" class="sh-form-inline" id="loginLangForm">
            <input type="hidden" name="returnUrl" value="/Auth/Login"/>
            @{
                var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
                var langItems = new SelectList(new[]
                {
                    new { V = "fr", T = "🇫🇷 FR" },
                    new { V = "en", T = "🇬🇧 EN" },
                    new { V = "de", T = "🇩🇪 DE" }
                }, "V", "T", lang);
            }
            <select name="culture" class="sh-lang-select" asp-items="langItems"
                    onchange="document.getElementById('loginLangForm').submit()"></select>
        </form>
    </div>

    <div class="login-footer">
        &copy; 2026 SafeHome — Software Router TPI
    </div>
</div>
</body>
</html>
