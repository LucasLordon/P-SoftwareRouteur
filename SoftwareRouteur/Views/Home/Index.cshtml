@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Page header -->
<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">Dashboard</h1>
        <p class="sh-page-subtitle">Vue d'ensemble du réseau domestique</p>
    </div>
</div>

<!-- Stats cards -->
<div class="sh-stats-grid">
    <div class="sh-stat-card">
        <div class="sh-stat-header">
            <i class="bi bi-wifi"></i>
            <span>Clients Total</span>
        </div>
        <div class="sh-stat-value">@Model.TotalClients</div>
    </div>
    <div class="sh-stat-card">
        <div class="sh-stat-header">
            <i class="bi bi-activity"></i>
            <span>En ligne</span>
        </div>
        <div class="sh-stat-value">@Model.OnlineClients</div>
    </div>
    <div class="sh-stat-card">
        <div class="sh-stat-header">
            <i class="bi bi-shield-check"></i>
            <span>Règles actives</span>
        </div>
        <div class="sh-stat-value">@Model.ActiveRules</div>
    </div>
    <div class="sh-stat-card">
        <div class="sh-stat-header">
            <i class="bi bi-shield-x"></i>
            <span>Bloqués aujourd'hui</span>
        </div>
        <div class="sh-stat-value">@Model.BlockedToday</div>
    </div>
</div>

<!-- Clients table -->
<div class="sh-card">
    <div class="sh-card-header">
        <h2 class="sh-card-title">Clients du réseau</h2>
        <a asp-controller="Client" asp-action="Index" class="sh-link">Gérer les clients →</a>
    </div>

    @if (Model.Clients.Any())
    {
        <table class="sh-table">
            <thead>
            <tr>
                <th>Hostname</th>
                <th>Adresse IP</th>
                <th>Statut</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var client in Model.Clients)
            {
                var isOnline = Model.ClientStatuses.ContainsKey(client.Id) && Model.ClientStatuses[client.Id];
                <tr>
                    <td class="sh-col-client">@client.Hostname</td>
                    <td class="sh-col-dest">@client.IpAddress</td>
                    <td>
                        <span class="sh-badge @(isOnline ? "sh-badge-allow" : "sh-badge-offline")">
                            @(isOnline ? "online" : "offline")
                        </span>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
    else
    {
        <div class="sh-empty">
            <i class="bi bi-people"></i>
            <p>Aucun client enregistré.</p>
        </div>
    }
</div>
