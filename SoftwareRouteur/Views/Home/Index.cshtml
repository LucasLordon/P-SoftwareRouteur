@model DashboardViewModel
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Page_Title"].Value;
}

<!-- Page header -->
<div class="sh-page-header">
    <div>
        <h1 class="sh-page-title">@Localizer["Page_Title"]</h1>
        <p class="sh-page-subtitle">@Localizer["Page_Subtitle"]</p>
    </div>
</div>

<!-- Stats cards -->
<div class="sh-stats-grid">
    <div class="sh-stat-card">
        <div class="sh-stat-header">
            <i class="bi bi-wifi"></i>
            <span>@Localizer["Stats_TotalClients"]</span>
        </div>
        <div class="sh-stat-value">@Model.TotalClients</div>
    </div>
    <div class="sh-stat-card">
        <div class="sh-stat-header">
            <i class="bi bi-activity"></i>
            <span>@Localizer["Stats_Online"]</span>
        </div>
        <div class="sh-stat-value">@Model.OnlineClients</div>
    </div>
    <div class="sh-stat-card">
        <div class="sh-stat-header">
            <i class="bi bi-shield-check"></i>
            <span>@Localizer["Stats_ActiveRules"]</span>
        </div>
        <div class="sh-stat-value">@Model.ActiveRules</div>
    </div>
    <div class="sh-stat-card">
        <div class="sh-stat-header">
            <i class="bi bi-shield-x"></i>
            <span>@Localizer["Stats_BlockedToday"]</span>
        </div>
        <div class="sh-stat-value">@Model.BlockedToday</div>
    </div>
</div>

<!-- Clients table -->
<div class="sh-card">
    <div class="sh-card-header">
        <h2 class="sh-card-title">@Localizer["Table_Title"]</h2>
        <a asp-controller="Client" asp-action="Index" class="sh-link">@Localizer["Manage_Link"]</a>
    </div>

    @if (Model.Clients.Any())
    {
        <table class="sh-table">
            <thead>
            <tr>
                <th>Hostname</th>
                <th>IP</th>
                <th>@Localizer["Col_Status"]</th>
            </tr>
            </thead>
            <tbody id="dashClientsBody">
            @foreach (var client in Model.Clients)
            {
                var isOnline = Model.ClientStatuses.ContainsKey(client.Id) && Model.ClientStatuses[client.Id];
                <tr>
                    <td class="sh-col-client">@client.Hostname</td>
                    <td class="sh-col-dest">@client.IpAddress</td>
                    <td>
                        <span class="sh-badge @(isOnline ? "sh-badge-allow" : "sh-badge-offline")">
                            @(isOnline ? Localizer["Badge_Online"] : Localizer["Badge_Offline"])
                        </span>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
    else
    {
        <div class="sh-empty">
            <i class="bi bi-people"></i>
            <p>@Localizer["Empty"]</p>
        </div>
    }

    <div class="sh-pagination" id="dashPagination">
        <button class="sh-page-btn" id="dashBtnPrev" onclick="dashChangePage(-1)">
            <i class="bi bi-chevron-left"></i>
        </button>
        <span class="sh-page-info" id="dashPageInfo"></span>
        <button class="sh-page-btn" id="dashBtnNext" onclick="dashChangePage(1)">
            <i class="bi bi-chevron-right"></i>
        </button>
        <select class="sh-page-size-select" onchange="dashChangePageSize(this.value)">
            <option value="5" selected>5 / page</option>
            <option value="10">10 / page</option>
            <option value="25">25 / page</option>
            <option value="50">50 / page</option>
        </select>
    </div>
</div>

@section Scripts {
    <script>
        let DASH_PAGE_SIZE = 5;
        let dashPage = 1;

        function dashRenderPage() {
            const rows = Array.from(document.querySelectorAll('#dashClientsBody tr'));
            const total = rows.length;
            const totalPages = Math.max(1, Math.ceil(total / DASH_PAGE_SIZE));
            dashPage = Math.min(dashPage, totalPages);
            const start = (dashPage - 1) * DASH_PAGE_SIZE;

            rows.forEach((row, i) => {
                row.style.display = (i >= start && i < start + DASH_PAGE_SIZE) ? '' : 'none';
            });

            document.getElementById('dashPageInfo').textContent = totalPages > 1 ? `${dashPage} / ${totalPages}` : '';
            document.getElementById('dashBtnPrev').disabled = dashPage <= 1;
            document.getElementById('dashBtnNext').disabled = dashPage >= totalPages;
            document.getElementById('dashBtnPrev').style.display = totalPages > 1 ? '' : 'none';
            document.getElementById('dashBtnNext').style.display = totalPages > 1 ? '' : 'none';
        }

        function dashChangePage(delta) {
            dashPage += delta;
            dashRenderPage();
        }

        function dashChangePageSize(val) {
            DASH_PAGE_SIZE = parseInt(val);
            dashPage = 1;
            dashRenderPage();
        }

        dashRenderPage();
    </script>
}
